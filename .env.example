# CourtMind — Environment Variables
# Copy this to .env and fill in your values. Never commit .env.

# ─── Qwen Cloud (DashScope) ───────────────────────────────────────
# Get from: https://dashscope-intl.aliyuncs.com
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
# Model: qwen-plus (default), qwen-max (best quality), or qwen-turbo (fastest).
# Avoid qwen2.5-72b-instruct on the intl endpoint — it is access-denied (403).
QWEN_MODEL=qwen-plus

# ─── Cognee Cloud ─────────────────────────────────────────────────
# COGNEE_API_KEY: Create from https://platform.cognee.ai → API Keys
# COGNEE_TENANT_URL: Your tenant URL from the Cognee Cloud dashboard
#   (e.g. https://your-tenant.aws.cognee.ai or similar)
# Use promo code COGNEE-35 for $35 free Developer plan credit on signup.
COGNEE_API_KEY=your-cognee-cloud-api-key-here
COGNEE_TENANT_URL=https://your-tenant.aws.cognee.ai
# Disable cognee's conversational session memory so search/recall return stored
# document facts (not chat-style replies). Required for contradiction detection.
CACHING=false

# ─── Frontend (Next.js .env.local) ───────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
# On Alibaba Cloud ECS: NEXT_PUBLIC_API_URL=http://<your-ecs-ip>:8000
